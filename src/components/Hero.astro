---
import type { Lang } from "@/i18n/languages";
import { useTranslations } from "@/i18n/utils";
import ChatPreview from "./ChatPreview.astro";
import PlatformBadgeRow from "./PlatformBadgeRow.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const title = t("hero.title");
const accent = t("hero.titleAccent");
const idx = title.indexOf(accent);
const before = idx >= 0 ? title.slice(0, idx) : title;
const after = idx >= 0 ? title.slice(idx + accent.length) : "";
const accentText = idx >= 0 ? accent : "";
---

<section class="relative overflow-hidden bg-white text-slate-900 dark:bg-slate-950 dark:text-white">
  <!-- Background mesh -->
  <div
    class="pointer-events-none absolute inset-0 -z-10 opacity-90 dark:opacity-60"
    style="background:
      radial-gradient(60% 80% at 15% 0%, rgba(56, 116, 250, 0.18) 0%, rgba(56, 116, 250, 0) 60%),
      radial-gradient(50% 70% at 95% 30%, rgba(167, 139, 250, 0.16) 0%, rgba(167, 139, 250, 0) 60%),
      radial-gradient(50% 60% at 50% 110%, rgba(45, 212, 191, 0.10) 0%, rgba(45, 212, 191, 0) 60%);"
  ></div>
  <!-- Grid -->
  <div
    class="pointer-events-none absolute inset-0 -z-10 opacity-[0.08] dark:opacity-[0.10]"
    style="background-image:
      linear-gradient(to right, rgb(15 23 42 / 1) 1px, transparent 1px),
      linear-gradient(to bottom, rgb(15 23 42 / 1) 1px, transparent 1px);
      background-size: 56px 56px;
      mask-image: radial-gradient(ellipse 80% 60% at 50% 30%, black 40%, transparent 100%);
      -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 30%, black 40%, transparent 100%);"
    aria-hidden="true"
  ></div>

  <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6 sm:py-24 lg:py-28">
    <div class="grid items-center gap-12 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.05fr)] lg:gap-14">
      <!-- Copy column -->
      <div class="text-center lg:text-left">
        <div class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white/80 px-3 py-1 font-mono text-[11px] font-medium uppercase tracking-[0.18em] text-slate-600 shadow-sm backdrop-blur dark:border-white/10 dark:bg-white/5 dark:text-slate-300">
          <span class="relative flex h-1.5 w-1.5">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
          </span>
          {t("hero.kicker")}
        </div>

        <h1 class="mt-6 text-4xl font-bold leading-[1.08] tracking-tight text-slate-900 sm:text-5xl lg:text-[3.5rem] dark:text-white">
          {before}
          {accentText && (
            <span class="bg-gradient-to-r from-primary-600 via-primary-500 to-accent-500 bg-clip-text text-transparent dark:from-primary-400 dark:via-primary-300 dark:to-accent-300">
              {accentText}
            </span>
          )}
          {after}
        </h1>

        <p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-slate-600 sm:text-xl lg:mx-0 dark:text-slate-300">
          {t("hero.subtitle")}
        </p>

        <div class="mt-8 flex flex-col items-center gap-3 sm:flex-row sm:gap-4 lg:items-start lg:justify-start">
          <a
            id="hero-cta-primary"
            href={`/${lang}/download/`}
            data-fallback-label={t("hero.cta.primaryGeneric")}
            data-template={t("hero.cta.primary")}
            class="group inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-primary-500 to-primary-600 px-7 py-3.5 text-base font-semibold text-white shadow-[0_10px_40px_-10px_rgba(56,116,250,0.5)] ring-1 ring-primary-700/10 transition hover:shadow-[0_10px_60px_-10px_rgba(56,116,250,0.7)] hover:brightness-110"
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
            </svg>
            <span data-cta-label>{t("hero.cta.primaryGeneric")}</span>
          </a>
          <a
            href={`/${lang}/features/`}
            class="inline-flex items-center gap-2 rounded-xl border border-slate-300 bg-white px-7 py-3.5 text-base font-semibold text-slate-700 transition hover:border-slate-400 hover:shadow-md dark:border-white/15 dark:bg-white/5 dark:text-slate-100 dark:hover:bg-white/10"
          >
            {t("hero.cta.secondary")}
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>

        <div class="mt-10 lg:mt-12">
          <PlatformBadgeRow lang={lang} />
        </div>
      </div>

      <!-- Mockup column -->
      <div class="relative mx-auto w-full max-w-xl lg:max-w-none">
        <ChatPreview lang={lang} />
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const a = document.getElementById("hero-cta-primary");
    if (!a) return;
    const label = a.querySelector("[data-cta-label]");
    if (!label) return;
    const ua = navigator.userAgent;
    let platform = "";
    if (ua.includes("Mac") && !/iPhone|iPad/.test(ua)) platform = "macOS";
    else if (ua.includes("Win")) platform = "Windows";
    if (platform) {
      const tpl = a.getAttribute("data-template") || "";
      label.textContent = tpl.replace("{platform}", platform);
    }
  })();
</script>
