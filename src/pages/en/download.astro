---
import BaseLayout from "@/layouts/BaseLayout.astro";
import DownloadCard from "@/components/DownloadCard.astro";
import { useTranslations } from "@/i18n/utils";
import { downloads, currentVersion, releaseDate } from "@/data/downloads";

const lang = "en";
const t = useTranslations(lang);

const macNotice = downloads.find((d) => d.notice === "macOSGatekeeper");
const winNotice = downloads.find((d) => d.notice === "windowsSmartscreen");
---

<BaseLayout
  title="Download"
  description="Download Link2Send v0.5.1 for macOS and Windows. iOS and Android coming after store review. Free and open source under MIT."
  lang={lang}
>
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="mx-auto max-w-2xl text-center">
        <h1 class="text-4xl font-bold text-slate-900 sm:text-5xl dark:text-white">
          {t("download.title")}
        </h1>
        <p class="mt-4 text-lg text-slate-600 dark:text-slate-300">
          {t("download.subtitle")}
        </p>
        <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
          {t("download.version")} <strong>{currentVersion}</strong> · {t("download.released")} {releaseDate}
        </p>
      </div>

      <div id="download-grid" class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {downloads.map((item) => (
          <DownloadCard item={item} lang={lang} />
        ))}
      </div>

      <div class="mt-12 grid gap-6 lg:grid-cols-2">
        {macNotice && (
          <div class="rounded-2xl border border-amber-200 bg-amber-50 p-5 dark:border-amber-900/40 dark:bg-amber-950/30">
            <h3 class="text-sm font-semibold text-amber-900 dark:text-amber-200">
              {t("download.notice.macos.title")}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-amber-900/80 dark:text-amber-200/80">
              {t("download.notice.macos.body")}
            </p>
          </div>
        )}
        {winNotice && (
          <div class="rounded-2xl border border-amber-200 bg-amber-50 p-5 dark:border-amber-900/40 dark:bg-amber-950/30">
            <h3 class="text-sm font-semibold text-amber-900 dark:text-amber-200">
              {t("download.notice.windows.title")}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-amber-900/80 dark:text-amber-200/80">
              {t("download.notice.windows.body")}
            </p>
          </div>
        )}
      </div>

    </div>
  </section>
</BaseLayout>

<script is:inline>
  (function () {
    const ua = navigator.userAgent;
    let platform = "";
    if (ua.includes("Win")) platform = "Windows";
    else if (ua.includes("Mac") && !/iPhone|iPad/.test(ua)) platform = "macOS";
    else if (/iPhone|iPad/.test(ua)) platform = "iOS";
    else if (ua.includes("Android")) platform = "Android";
    if (!platform) return;
    const card = document.querySelector(`#download-grid [data-platform="${platform}"]`);
    if (card) {
      card.classList.add(
        "border-primary-300",
        "dark:border-primary-700",
        "shadow-lg",
        "ring-2",
        "ring-primary-200",
        "dark:ring-primary-900/60"
      );
    }
  })();
</script>
